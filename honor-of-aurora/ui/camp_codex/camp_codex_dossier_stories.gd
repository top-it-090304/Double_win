extends RefCounted
class_name CampCodexDossierStories

const _EMPTY := "[color=#8899aa]Пока нет записей, которые можно считать известными по тому, что уже произошло. Возвращайся после новых встреч и походов.[/color]"


static func get_story_bbcode(character_key: String) -> String:
	match character_key:
		"hero":
			return _join_beats(_beats_hero())
		"healer":
			return _join_beats(_beats_healer())
		"youth":
			return _join_beats(_beats_youth())
		"veteran":
			return _join_beats(_beats_veteran())
		_:
			return _EMPTY


static func _join_beats(beats: Array) -> String:
	var out := ""
	var any := false
	for b in beats:
		var d: Dictionary = b
		var flg: String = String(d.get("flag", ""))
		if flg != "" and not StoryState.has_flag(flg):
			continue
		any = true
		var title: String = String(d.get("title", ""))
		var body: String = String(d.get("body", ""))
		out += "[font_size=17][b]%s[/b][/font_size]\n[color=#c8d0e0]%s[/color]\n\n" % [title, body]
	if not any:
		return _EMPTY
	return out.strip_edges()



static func pick_exchange() -> Dictionary:
	if EXCHANGES.is_empty():
		return {"q": "…", "a": "…"}
	return EXCHANGES[randi() % EXCHANGES.size()]


static func format_question_for_choice_button(question: String, max_chars: int = 140) -> String:
	var s := question.strip_edges()
	s = s.replace("\n", " ")
	while s.contains("  "):
		s = s.replace("  ", " ")
	if s.length() <= max_chars:
		return s
	return s.substr(0, max(0, max_chars - 1)).strip_edges() + "…"

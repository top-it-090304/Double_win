static var _pool: Array[int] = []
static var _last_idx: int = -1


static func pick_next() -> String:
	if QUOTES.is_empty():
		return ""
	if _pool.is_empty():
		_refill_pool()
	var idx: int = _pool.pop_back()
	_last_idx = idx
	return String(QUOTES[idx])


static func _refill_pool() -> void:
	_pool.clear()
	for i in range(QUOTES.size()):
		_pool.append(i)
	_pool.shuffle()
	if _pool.size() > 1 and _last_idx >= 0 and _pool[_pool.size() - 1] == _last_idx:
		var k: int = randi_range(0, _pool.size() - 2)
		var tmp: int = _pool[_pool.size() - 1]
		_pool[_pool.size() - 1] = _pool[k]
		_pool[k] = tmp

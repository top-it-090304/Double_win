## Контуры навигации базового острова (локальные координаты IslandNavigationRegion): внешний + дыры под стены.
## Восстановлено из прежней сцены; при ошибке сборки island_navigation_region.gd откатится на простой прямоугольник.


static func get_outline_arrays() -> Array[PackedVector2Array]:
	return [
		_outer(),
		_hole_a(),
		_hole_b(),
		_hole_c(),
		_hole_d(),
	]



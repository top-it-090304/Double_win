extends DialogueSequence

## Финал линии монаха, если герой отказался снимать последний узел.


func ensure_lines_ready() -> void:
	if not lines.is_empty():
		return
	id = "monk_finale_refused"
	var arr: Array[DialogueLine] = []
	arr.append(_line("healer", "Ты остановился. Последний страж стоит. Заря продолжает спать."))
	arr.append(_line("healer", "Корона не получит акта о стабилизации. Рудники останутся закрытыми. Маяки на материке продолжат гаснуть."))
	arr.append(_line("healer", "А я… не получу свой билет. Контракт ордена останется открытым. До стабилизации. То есть — до конца."))
	arr.append(_line("hero", "Мне жаль. Правда жаль."))
	arr.append(_line("healer", "Знаю. Я вижу это в твоих глазах. И именно поэтому не могу злиться."))
	arr.append(_line("healer", "Ты принял решение, которое я не смог бы принять сам. Ты поставил неизвестность — то, что может случиться, если Заря проснётся, — выше конкретной боли: моей, короны, своей карьеры."))
	arr.append(_line("healer", "Может быть, это и есть честь. Не та, которую вешают на стену. Та, которая мешает спать."))
	arr.append(_line("hero", "Что ты будешь делать?"))
	arr.append(_line("healer", "Сяду у огня. Напишу письмо дочери. Не «прощай» — «жди». Потому что я всё ещё верю, что когда-нибудь найдётся другой путь. Не через мечи и замки. Но это — уже не для первой части истории."))
	if StoryState.has_flag("worker_youth_dead"):
		arr.append(_line("healer", "Юноша мёртв. Ты отказался от последнего стража. Два решения, за которые ты заплатишь по-разному. Одно — совестью. Другое — чистыми руками, которые не все оценят."))
	arr.append(_line("narrator", "Последний страж стоит. Заря спит. Рыцарь уходит с чистой совестью и чужой болью на плечах. Корона уже ищет другой меч. Первая часть окончена."))
	lines = arr


func _line(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

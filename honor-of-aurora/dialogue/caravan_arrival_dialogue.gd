extends DialogueSequence
class_name CaravanArrivalDialogue

## Причал: лодка Короны. Интендант — казённый снабженец, говорит с почтением.
## Степень уважения нарастает от титула к титулу; герой — рыцарь, будущий лорд.
## Даже при немилости — всегда уважительно: интендант передаёт чужие слова, а не свои.
## При покупке руды за реальные деньги (патрон) — отдельный блок благодарности без четвёртой стены.
## Немилость 1–3: «голос двора» + урезанная выплата + прощание.


func ensure_lines_ready() -> void:
	lines.clear()
	id = "caravan_arrival"

	var order_index := SaveManager.crown_order_index
	var displeasure := clampi(SaveManager.crown_displeasure, 0, BalanceConfig.DISPLEASURE_MAX_LEVEL)
	var caravan_count := SaveManager.caravan_sent_count
	var title_idx := BalanceConfig.get_crown_title_index_for_ore_sent(SaveManager.ore_sent_to_crown_total)
	var patron_idx := BalanceConfig.get_patron_tier_index(SaveManager.premium_ore_purchased_total)
	var variant := _arrival_variant(caravan_count, order_index, title_idx)

	if caravan_count <= 0:
		_build_first_caravan(variant, displeasure)
	else:
		_build_regular_caravan(displeasure, title_idx, variant)

	if patron_idx >= 0:
		_build_patron_recognition(patron_idx, variant)

	_build_letter_delivery()
	_build_order_announcement(order_index)
	_build_farewell(displeasure, title_idx, variant)


func _arrival_variant(caravan_count: int, order_index: int, title_idx: int) -> int:
	return absi(caravan_count * 19 + order_index * 11 + title_idx * 5) % 4


#region Первый приезд


func _build_first_caravan(variant: int, displeasure: int) -> void:
	var narr := [
		"У причала вторая лодка — казённая, с гербом Короны. Привезли жалование и бумаги.",
		"У пирса чужой борт — лодка из столицы, тяжёлая от груза. Ждут решения.",
		"Казённый борт пришёл: у причала две лодки — ваша и коронная. На берегу — человек в казённом плаще.",
		"К пирсу причалила вторая лодка. Герб Короны на борту, мешки под тентом. Интендант ждёт на берегу.",
	]
	lines.append(_plain("narrator", narr[variant % narr.size()]))

	var intro := [
		[
			"Милорд, золото и мясо уже на складе — по норме. Я интендант коронного снабжения: почта, свёртки и учёт по списку. Всё, что касается Сердцевины, — в замке, под печатью канцелярии.",
			"Буду приходить по графику: привезу положенное, заберу то, что подпишут с печатью. Пока наша лодка у пирса — к следующему приезду рейса не приближаетесь; канцелярия срок ведёт без меня.",
		],
		[
			"Милорд, положенное на складе, я сам принял по списку. Пакеты и письма — моя забота; остальное в замке разберут, не при мне.",
			"Я только вожу ящики: что велено — привёз, жду распоряжений. Пока в замке не решили — к следующему приезду каравана не приближаетесь; срок по указу в столице ведут не у лодки.",
		],
		[
			"Милорд, не извольте беспокоиться: золото и мясо снесли на склад по ведомости. Я при лодке — доставка и учёт. Про Сердцевину скажут те, у кого подпись и печать.",
			"Рейсы держу как могу. Пока наша лодка у пирса — время до следующего прибытия каравана для лагеря не убегает вперёд; срок канцелярии к тому же не привязан к тому, стою ли я у борта.",
		],
		[
			"Милорд, позвольте представиться: интендант при казённом борте. Жалование и припасы уже на складе. Дальше — запись из канцелярии в замке; при мне только учёт и мешки.",
			"Коронный борт ходит по графику — я у причала в положенный час. К следующему приезду не приближаетесь, пока я стою с грузом или жду отпуска; срок у канцелярии идёт своим чередом.",
		],
	]
	var fo: Array = intro[variant % intro.size()]
	lines.append(_plain("caravan", str(fo[0])))
	lines.append(_plain("caravan", str(fo[1])))

	if displeasure >= 1:
		lines.append(_plain("caravan", _royal_displeasure_pick(displeasure, variant)))

	var hero_first := [
		"Вижу казённую лодку — значит, ждут решения по грузу. Зайду в замок: там под печатью Короны решат, что отправлять в столицу.",
		"Понятно. Пока их лодка у пирса, следующий рейс не приближается — срок по указу у канцелярии к тому же не замирает. Надо доложить в замке и распорядиться по правилам.",
		"Вторая лодка — не разговор у борта, а связь с Короной. Что с Сердцевиной — запишут в замке; я сделаю, как решат.",
		"Принято. В замке всё устроено — приказ, мешки, печать. Там и распоряжусь.",
	]
	lines.append(_plain("hero", hero_first[variant % hero_first.size()]))


#endregion


#region Обычный приезд


func _build_regular_caravan(displeasure: int, title_idx: int, variant: int) -> void:
	var narr_tier: Array = _tier_narrator_pool(title_idx)
	lines.append(_plain("narrator", str(narr_tier[variant % narr_tier.size()])))

	if displeasure >= 1:
		lines.append(_plain("caravan", _royal_displeasure_pick(displeasure, variant)))
		lines.append(_plain("caravan", _payment_line_for_displeasure(displeasure, variant)))
	else:
		var car_tier: Array = _tier_greeting_pool(title_idx)
		lines.append(_plain("caravan", str(car_tier[variant % car_tier.size()])))


func _tier_narrator_pool(title_idx: int) -> Array:
	match clampi(title_idx, 0, 5):
		0:
			return [
				"Казённая лодка у пирса — ждут решения в замке.",
				"Вторая лодка пришла: рейс Короны на месте.",
				"У причала чужой борт — интендант с ящиками.",
				"Казённый борт причалил. Мешки под тентом, на борту — герб Короны.",
			]
		1:
			return [
				"Лодка стоит у пирса — в отчётах из столицы ваше имя заметнее, чем раньше.",
				"Казённый рейс: в порту говорят, что партии с вашего лагеря идут ровно.",
				"Вторая лодка — снова припасы и печати. В столице начинают запоминать, откуда руда.",
				"Борт Короны у причала. Интендант сходит уверенно — знает этот пирс.",
			]
		2:
			return [
				"Лодка Короны у причала. Без руды с этих островов маякам на материке трудно.",
				"Казённый борт у пирса — снова пора показать, что цепь снабжения жива.",
				"Рейс пришёл: на большой земле помнят, откуда берут Сердцевину.",
				"Борт тяжёлый — припасов больше, чем в первые рейсы. Казна ценит стабильность.",
			]
		3:
			return [
				"Судно у причала — о вас в столице слышат не только в конторе с деньгами.",
				"Вторая лодка на месте. В гавани ваше имя уже что-то значит — и не только в графах.",
				"Казённый рейс у пирса — интендант поклонился ещё с борта.",
				"Борт Короны причалил мягко. Интендант сходит первым — привычка или почтение.",
			]
		4:
			return [
				"Лодка Короны у причала — о вас говорят при дворе рядом с именем Авроры.",
				"Рейс пришёл: печати свежие, мешки тяжёлые. Лагерь снова на карте — и не мелким шрифтом.",
				"Борт Короны у причала — интендант поправляет плащ, прежде чем сойти. Этот берег обязывает.",
				"Казённая лодка встала у пирса. Даже матросы притихли — знают, чей это берег.",
			]
		_:
			return [
				"Лодка Короны у причала — о вас помнят при дворе, и не шёпотом.",
				"Казённый рейс: казна не просто шлёт ящики — она отвечает на ваши заслуги.",
				"Борт Короны причалил. Интендант сошёл с поклоном — сюда уже не шлют случайных людей.",
				"Лодка Короны стоит у пирса. Этот берег знают в столице по имени его хозяина.",
			]


func _tier_greeting_pool(title_idx: int) -> Array:
	match clampi(title_idx, 0, 5):
		0:
			return [
				"Милорд, полная выплата на складе. Сроки смотрят в канцелярии — я при лодке.",
				"Сударь, золото и мясо снесли по ведомости. Дальше — бумаги и приказ из замка.",
				"Милорд, жалование целиком. Я только доставил; дальше — ваше слово.",
				"Милорд, положенное на месте. Рад видеть вас в добром здравии у пирса.",
			]
		1:
			return [
				"Милорд, положенное на складе. В столице ваши партии отмечают — рад снова видеть вас лично.",
				"Милорд, выплата полная. Слышал: отчёты с Авроры вас хвалят. Не мне судить, но рад за вас.",
				"Милорд, всё по норме на складе. Если б выбирал маршрут — с вами бы и дальше ходил.",
				"Милорд, жалование без задержек. Приятно везти мешки туда, где ценят порядок.",
			]
		2:
			return [
				"Милорд, жалование на месте, полное. Про маяки говорят те, кто повыше; я вожу ящики — но знаю, для чего они горят.",
				"Милорд, положенное доставлено. Цепь Сердцевины держится на таких, как вы. Я только верёвки проверяю.",
				"Милорд, выплата целиком. Снова увидеть того, кто кормит огни большой земли, — для меня уже награда.",
				"Милорд, на складе полная норма. Маяки горят — и в этом свете я вижу вашу руку.",
			]
		3:
			return [
				"Милорд, о вас говорят так, что мне, интенданту, стоять рядом — честь. Полная выплата на складе.",
				"Милорд, положенное у вас. При дворе любят титулы, а я люблю тишину под палубой — но сегодня рад оказаться здесь.",
				"Милорд, жалование целиком. Учить вас не мне; кланяюсь и надеюсь, что следующий рейс снова ваш.",
				"Рыцарь Сердцевины — так вас зовут в казённых реестрах, милорд. Выплата полная, как и полагается вашему званию.",
			]
		4:
			return [
				"Милорд, о вас при дворе говорят рядом с Авророй — я слышал от писаря. Простите дерзость повторить. Полная выплата на складе.",
				"Милорд, положенное доставлено. Нести мешки на ваш берег — привилегия, которой удостоит не каждый маршрут.",
				"Милорд, выплата полная. Видеть вас после тёмного трюма — как свет увидеть после шторма.",
				"Милорд, Хранитель Авроры — не просто строка в реестре. Это человек, которому кланяются у борта. Всё на складе, как положено.",
			]
		_:
			return [
				"Милорд, о вас в столице говорят так, что мне неловко рядом стоять. Полная выплата на складе — и поклон от всей команды.",
				"Милорд, положенное доставлено. Красивые речи не мои; скажу просто: честь стоять у вашего борта.",
				"Милорд, жалование целиком. Увёз бы вас в столицу, если б мог, а не только руду. Там вас ждут с почестями.",
				"Герой Короны — так в летописях, так и у причала, милорд. Мне нечего добавить, кроме почтения и полной выплаты.",
			]


#endregion


#region Немилость


func _royal_displeasure_pick(level: int, variant: int) -> String:
	var pool: Array = _royal_displeasure_pool(level)
	return str(pool[variant % pool.size()])


func _royal_displeasure_pool(level: int) -> Array:
	match clampi(level, 1, BalanceConfig.DISPLEASURE_MAX_LEVEL):
		1:
			return [
				"Милорд, простите… мне передали сухо: во дворе недовольны сроками. Не серчайте на гонца — я только повторяю.",
				"Милорд, из столицы наказали сказать: приказ ждут, а ответ запаздывает. Мне стыдно за тон, но письмо жёсткое.",
				"Милорд, тихо скажу: Корона не привыкла ждать. Сегодня ещё вежливо — завтра бумага может стать короче.",
				"Милорд, не моё место давать советы, но из столицы пришли слова, которые лучше услышать сейчас, чем потом в приказе.",
			]
		2:
			return [
				"Милорд, велели передать прямо: двор считает, что дело стоит. Я ниже грязи на сапоге — но слова не мои, а канцелярии.",
				"Милорд, из канцелярии без смягчений: либо руда пошла, либо отчёт будет плохой. Я только везу ящики и плохие новости.",
				"Милорд, так сказали при печати: терпение кончается. Если бы я мог — промолчал бы; велели донести.",
				"Милорд, мне стыдно за тон, каким это написано. Но передаю слово в слово: «двор ждёт руду, а не объяснений».",
			]
		_:
			return [
				"Милорд… страшно даже повторять: Корона в гневе. Про приказ говорят уже не как про просьбу. Я бы уполз в трюм, да долг — донести.",
				"Милорд, последнее предупреждение: «без оговорок». Дальше не только жалованье урежут. Я молюсь, чтобы вы успели.",
				"Милорд, как есть: из столицы шлют не благодарность. Смысл простой — исполнить всерьёз, иначе достанется всему лагерю.",
				"Милорд, мне велели передать гнев Короны. Я передаю. И прошу — не за себя, за весь берег — успейте.",
			]


func _payment_line_for_displeasure(level: int, variant: int) -> String:
	match clampi(level, 1, BalanceConfig.DISPLEASURE_MAX_LEVEL):
		1:
			var a := [
				"Милорд, жалование урезали — на складе ровно то, что насчитали. Я не при чём, только доставил.",
				"Милорд, из-за сроков выплата сегодня меньше. Гнев не на меня — я при лодке.",
				"Милорд, положенное дали не всё: так приказали сверху. Я бы добавил из своего, да карман пуст.",
				"Милорд, на складе — норма с вычетом. Простите, что приношу такие вести.",
			]
			return a[variant % a.size()]
		2:
			var b := [
				"Милорд, на складе остаток после штрафа. Про Сердцевину в столице не шутят — простите за грубый тон их бумаг.",
				"Милорд, жалованье сильно урезали. Приказ по руде не снят; дальше тянуть — страшно даже мне.",
				"Милорд, дали мало — специально. Велели, чтобы дошло: времени почти не осталось.",
				"Милорд, казна наказала урезать выплату. На складе — меньше обычного. Мне жаль, что везу так мало.",
			]
			return b[variant % b.size()]
		_:
			var c := [
				"Милорд, на складе минимум. Без отгрузки дальше будет хуже — даже для вас, так сказали.",
				"Милорд, Корона на пределе: сегодня почти пустые мешки. В отчёте ждут руду, а не оправданий.",
				"Милорд, жалование на дне. Если сорвёте срок — боюсь, следующий рейс придёт уже не с припасами.",
				"Милорд, мешки почти пусты — так велели. Мне больно везти так мало тому, кому обязан стоять навытяжку.",
			]
			return c[variant % c.size()]


#endregion


#region Благодарность (патрон)


func _build_patron_recognition(patron_idx: int, variant: int) -> void:
	var pool: Array = _patron_pool(patron_idx)
	if pool.is_empty():
		return
	lines.append(_plain("caravan", str(pool[variant % pool.size()])))


func _patron_pool(patron_idx: int) -> Array:
	match clampi(patron_idx, 0, 3):
		0:
			return [
				"Милорд, заметил при разгрузке: на складе сегодня больше, чем по казённой ведомости. Кто-то позаботился о лагере щедрее, чем требовал приказ.",
				"Милорд, странное дело — запасы на берегу растут быстрее, чем я вожу. Видно, судьба у этого лагеря особая.",
				"Милорд, мне положено считать мешки. Так вот: их больше, чем значится в реестре. Хорошая загадка — и хорошая новость для берега.",
				"Милорд, припасов в лагере больше, чем я привёз за все рейсы. Не мне гадать откуда — но берегу от этого только лучше.",
			]
		1:
			return [
				"Милорд, лагерь снабжён так, что казначей бы трижды пересчитал. Не каждый берег видит такую заботу — и не каждый её заслуживает.",
				"Милорд, я прибывал на десятки берегов, но здесь запасы растут, будто кто-то вкладывает в этот лагерь душу. Служить такому берегу — привилегия.",
				"Милорд, то, что я вижу на складе, — больше, чем может дать одна лодка. Значит, есть те, кто верит в этот лагерь не только на словах.",
				"Милорд, мне не положено удивляться. Но щедрость, которой дышит этот берег, заставляет снять шляпу — если бы она у меня была.",
			]
		2:
			return [
				"Милорд, летописцы у причала записали: ваш берег — единственный в цепи, где запасы растут быстрее, чем их тратят. Такого не бывает без особой воли и особого сердца.",
				"Милорд, при разгрузке матросы шепчутся: на этом острове — щедрость, которой нет ни на одном другом берегу. Хроники запомнят не только руду, но и тех, кто её обеспечил.",
				"Милорд, в моих отчётах ваш лагерь стоит отдельной строкой. Такое снабжение — не удача и не случай. Это чья-то воля, достойная летописи.",
				"Милорд, мне, интенданту, не положено говорить красиво — но скажу: что-то в этом лагере выше обычного порядка вещей. Служить этому берегу — честь, которую не выписывают в казённых ведомостях.",
			]
		_:
			return [
				"Милорд… я интендант, я привык не удивляться. Но то, что происходит с этим лагерем, — выходит за пределы любого приказа Короны. Такую заботу не выписывают указом. Её дарят.",
				"Милорд, за все мои годы на казённом борте я не видел берега, которому помогали бы так. Если когда-нибудь в хрониках напишут о щедрости, достойной легенды, — пусть напишут про этот берег.",
				"Милорд, мне нечем отплатить за то, что я вижу. Но клянусь рулём и морем: если маяки горят, если рейсы не пусты — за этим стоит не только ваш меч, но и чьё-то невероятное сердце.",
				"Милорд, простите дерзость, но промолчать не могу: я всю жизнь возил ящики и считал мешки. Этот лагерь — первое место, где я почувствовал, что за цифрами стоит что-то большее. Кто-то вложил в этот берег не только руду — а веру.",
			]


#endregion


#region Письма, приказ, прощание


func _build_letter_delivery() -> void:
	var has_pending_miron_letter := (
		StoryState.has_flag("worker_youth_dead")
		and StoryState.has_flag("youth_belongings_found")
		and not StoryState.has_flag("youth_letter_sent_done")
	)
	var has_lian_letter_1 := (
		StoryState.has_flag("monk_story_3_done")
		and not StoryState.has_flag("monk_letter_1_read")
	)

	if has_lian_letter_1:
		lines.append(_plain("caravan", "Милорд, письмо целителю — почерк детский."))
		lines.append(_plain("hero", "Приму. Передам целителю лично."))

	if has_pending_miron_letter:
		lines.append(
			_plain(
				"hero",
				"Есть конверт на материк — матери погибшего мальчика. Положите к казённым мешкам для отгрузки."
			)
		)
		lines.append(_plain("caravan", "Слушаюсь, милорд. Приму к отгрузке."))

	var knew_youth_letters := StoryState.has_flag("youth_letter_1_done")
	if knew_youth_letters and not StoryState.has_flag("worker_youth_dead"):
		if StoryState.has_flag("youth_letter_2_done"):
			lines.append(_plain("caravan", "Милорд, с материка ответ для юноши — от матери."))


func _ru_day_word_counted(n: int) -> String:
	var a := absi(n)
	var n10 := a % 10
	var n100 := a % 100
	if n100 >= 11 and n100 <= 14:
		return "дней"
	if n10 == 1:
		return "день"
	if n10 >= 2 and n10 <= 4:
		return "дня"
	return "дней"


func _build_order_announcement(order_index: int) -> void:
	var order := BalanceConfig.get_crown_order(order_index)
	if order.is_empty():
		return
	var ore_req := int(order.get("ore_required", 0))
	var letter_text := str(order.get("letter", ""))
	var deadline := int(order.get("deadline_expeditions", BalanceConfig.DEFAULT_CROWN_ORDER_DEADLINE_EXPEDITIONS))
	var dl_word := _ru_day_word_counted(deadline)

	lines.append(
		_plain(
			"caravan",
			"Запись из канцелярии, милорд: сдать %d ед. Сердцевины; срок исполнения — %d %s по графику канцелярии (в лагере считаются сутки после каждого возвращения с острова). Пока лодка у пирса — следующий приезд каравана не приближается; срок по приказу идёт отдельно, так в приказе."
			% [ore_req, deadline, dl_word]
		)
	)
	if not letter_text.is_empty():
		lines.append(_plain("caravan", "Слова с королевской печатью, дословно: «%s»" % letter_text))


func _build_farewell(displeasure: int, title_idx: int, variant: int) -> void:
	lines.append(
		_plain(
			"caravan",
			"Жду распоряжения по отгрузке, милорд. В замке решат — грузить Сердцевину или отпустить нас порожняком.",
		)
	)
	lines.append(
		_plain(
			"caravan",
			"Пока в замке не решат дело, время до следующего рейса стоит. Срок у канцелярии к тому же не замирает из-за моей стоянки у воды. Я только работаю у воды.",
		)
	)
	if displeasure <= 0:
		var motiv := _farewell_motivation_pool(title_idx)
		lines.append(_plain("caravan", str(motiv[variant % motiv.size()])))
	else:
		var close_pool: Array = _farewell_displeasure_pool(displeasure, variant)
		lines.append(_plain("caravan", str(close_pool[variant % close_pool.size()])))


func _farewell_motivation_pool(title_idx: int) -> Array:
	match clampi(title_idx, 0, 5):
		0:
			return [
				"Корона, милорд, не любит, когда сроки пляшут — я бы и сам волновался, да не мне решать.",
				"Сдаёте руду вовремя — жалование и отчёт будут ровными. Я за вас держу кулаки.",
				"Чем спокойнее рейс «пришёл — увёз», тем меньше в столице лишних вопросов. Нам всем легче.",
				"Милорд, удачи с решением. Я буду у лодки — куда мне деваться.",
			]
		1:
			return [
				"Милорд, казна любит честные цифры — я вру только матросам про порцию каши.",
				"Ещё пару чистых отгрузок — и о вас скажут выше моей должности. Я потом буду хвастать, что знал вас лично.",
				"Партии идут ровно — держите линию. От этого зависит, как часто сюда шлют мешки, а не проверяющих.",
				"Милорд, хорошие рейсы — редкость на моём маршруте. Рад, что ваш берег — один из них.",
			]
		2:
			return [
				"Маяки на материке, милорд, держатся на вашей руде — я лишь подставляю спину под ящики.",
				"Цепь снабжения держится звеньями. Я звено грязное, но верное.",
				"Отгрузите вовремя — в столице скажут, что огни не угасли. Я повторю при случае, если не возражаете.",
				"Милорд, страж огня на большой земле — это вы. Я страж мешков. Каждый при своём.",
			]
		3:
			return [
				"Милорд, казне нужны мешки, не праздничные речи — я несу мешки, вы — честь.",
				"Двор слышит имена. Я слышу скрип досок — но рад, что до меня доходит и ваше имя.",
				"Не заставляйте казённую лодку зря ждать — на пирсу я старею быстрее, чем в море.",
				"Милорд, рыцарь вы или нет — для меня важнее, что рейс был не зря. А он не зря.",
			]
		4:
			return [
				"Милорд, Короне нужна опора на этой воде — я не опора, я гвоздь в сапоге; но за вас держусь.",
				"Имя ваше в бумагах рядом с Авророй. Не дайте повода для плохого шёпота — я от писарей всегда держался подальше.",
				"Оправдайте ожидание столицы ещё раз — может, мне и место у борта потеплее достанется.",
				"Милорд, Хранитель — это не просто слово в реестре. Это ответственность, которой я бы позавидовал, если б не боялся высоты.",
			]
		_:
			return [
				"Милорд, страна смотрит на тех, кого хвалят при дворе — я смотрю в пол, но для вас подниму глаза.",
				"Каждая чистая отгрузка — строка в вашей судьбе, не в моей. Я только машу рукой в воздухе.",
				"Корона возложила на вас больше, чем на меня — я отдам рейсу всё, лишь бы не подвести.",
				"Милорд, Герой Короны — не то, что вмещается в ведомость. Скажу одно: служить вашему берегу — лучшее, что случилось на казённой лодке.",
			]


func _farewell_displeasure_pool(level: int, variant: int) -> Array:
	match clampi(level, 1, BalanceConfig.DISPLEASURE_MAX_LEVEL):
		1:
			return [
				"Милорд, одно честное слово: исправьтесь, пока говорят спокойно. Я бы не хотел везти следующую весть хуже.",
				"Милорд, я за вас не в ответе — но пусть следующий отчёт будет без красных пометок.",
				"Милорд, время ещё есть. Пусть следующий мой приход будет с полными мешками и мягкой бумагой.",
				"Милорд, дерзну попросить: не откладывайте. Чем раньше руда пойдёт — тем быстрее забудут.",
			]
		2:
			return [
				"Милорд, если честно — дальше шуток не будет. Я молюсь, чтобы вы успели до следующего гнева.",
				"Милорд, я никто, но даже мне страшно читать, что шлют. Покажите, что лагерь не подвёл.",
				"Милорд, за вас не поручусь — поручусь только, что донёс как есть. Вытащите ситуацию, пока печать не ударила сильнее.",
				"Милорд, не мне вас учить — но тон писем меняется. Следующий рейс может стать последним спокойным.",
			]
		_:
			return [
				"Милорд, если сорвёте и это — боюсь, мой рейс сюда станет редким. И не с припасами. Спасайте, что можно.",
				"Милорд, я в последний раз говорю мягко: двор не шлёт такие строки тем, кого хотят беречь.",
				"Милорд, дальше решать вам — я только уношу ответ. Пусть в том ответе будет руда, а не оправдания.",
				"Милорд, я боюсь за этот берег. Если можете — покажите Короне, что лагерь жив. Иначе — не знаю.",
			]


#endregion


func _plain(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

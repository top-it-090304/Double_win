const _IDLE: Array[String] = [
	"Ничего нового. Ветер, мишени, хромота. Обычный день.",
	"Тихо. Даже странно.",
	"Сегодня без историй. Только стрелы и небо.",
]


func ensure_lines_ready() -> void:
	_ensure_lines()


func _ensure_lines() -> void:
	if not lines.is_empty():
		return
	id = "veteran_archer_banter"
	var rng := RandomNumberGenerator.new()
	rng.randomize()
	var text: String
	if rng.randf() < 0.2:
		text = _IDLE[rng.randi() % _IDLE.size()]
	else:
		text = _POOL[rng.randi() % _POOL.size()]
	lines = [_line("veteran", text)]


func _line(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

const _IDLE_FILLER: Array[String] = [
	"Тихий день. Пей. Не требуй драмы — в запасе маловато.",
	"Новостей нет, кроме твоих ран. Это почти удобно.",
	"На сегодня: отвар, тишина, котёл не убежал. Остальное — потом.",
	"Если ждёшь откровения — в котле сегодня только буль, без метафизики.",
	"Сил хватает на флакон и молчание. Это уже немало.",
]


func ensure_lines_ready() -> void:
	_ensure_lines()


func _ensure_lines() -> void:
	if not lines.is_empty():
		return
	id = "heal_banter"
	var rng := RandomNumberGenerator.new()
	rng.randomize()
	var text: String
	if rng.randf() < 0.18:
		text = _IDLE_FILLER[rng.randi() % _IDLE_FILLER.size()]
	else:
		text = _POOL[rng.randi() % _POOL.size()]
	lines = [_line("healer", text)]


func _line(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

extends DialogueSequence

func ensure_lines_ready() -> void:
	if not lines.is_empty():
		return
	id = "monk_worker_youth_warning"
	lines.append(_plain("healer", "Странник. Сядь. Мне нужно сказать тебе кое-что про юношу, пока ты не наделал глупостей."))
	lines.append(_plain("healer", "Я лечил таких, как он. Знаешь, что остаётся от мечтателя после первого настоящего боя? Не шрам — пустота в глазах. Он думает, что поход — это слава. Поход — это грязь, кровь и крик, который не помещается в горло."))
	lines.append(_plain("healer", "Если ты возьмёшь его с собой на острова — он погибнет. Не «может погибнуть». Погибнет. Он не обучен, не закалён, не готов. Он оступится, не увидит засаду, будет слишком медленный. Я видел это десятки раз."))
	lines.append(_plain("healer", "А если чудом выживет — сломается так, что я не зашью. Есть раны, от которых нет отвара."))
	lines.append(_plain("healer", "На базе он полезен: руда, склад, смены. Живой и при деле. Это не трусость — это разум."))
	lines.append(_plain("healer", "Ты потерял людей на переправе — сам мне рассказал. Не повторяй. Этот юноша — не твой шанс на искупление. Он — чужая жизнь. Распорядись ею лучше, чем прошлыми."))


func _plain(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

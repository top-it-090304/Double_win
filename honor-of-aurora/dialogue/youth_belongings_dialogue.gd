extends DialogueSequence


func ensure_lines_ready() -> void:
	if not lines.is_empty():
		return
	id = "youth_belongings"

	var knew_camp: bool = StoryState.has_flag("worker_youth_camp_done")
	var knew_letter1: bool = StoryState.has_flag("youth_letter_1_done")
	var knew_letter2: bool = StoryState.has_flag("youth_letter_2_done")

	if knew_camp:
		lines.append(_plain("narrator", "Койка юноши. Одеяло свёрнуто аккуратно — он всегда так делал. Ты помнишь: он рассказывал, что мать научила. «Складывай ровно — значит, вернёшься»."))
	else:
		lines.append(_plain("narrator", "Койка юноши. Одеяло свёрнуто аккуратно — аккуратнее, чем у любого солдата. Под подушкой — жестянка с монетами. Немного."))

	if knew_camp:
		lines.append(_plain("narrator", "Под подушкой — жестянка с монетами. Он говорил: «Купи Нике ботинки». Ты помнишь."))

	lines.append(_plain("narrator", "На матрасе — белая ракушка. Обломанная, с трещиной. Не самая большая."))
	if knew_letter2:
		lines.append(_plain("narrator", "Он искал лучше — на каждом острове. «Самую большую на всём берегу». Для Ники. Эта — не та. Но другой не будет."))
	elif knew_letter1:
		lines.append(_plain("narrator", "Ты не знал, зачем он собирал ракушки. Теперь — догадываешься."))
	else:
		lines.append(_plain("narrator", "Зачем мальчишка-солдат хранил ракушку на койке? Ты не знаешь. Может, узнаешь из писем."))

	if knew_letter1:
		lines.append(_plain("narrator", "Мятый рисунок: кораблик с кривым парусом, волны зигзагом, солнце в углу. Подпись: «Братику на остраф». Ника старалась. Ты видел — он носил его в кармане."))
	else:
		lines.append(_plain("narrator", "Мятый листок. Детский рисунок: кораблик, волны, солнце в углу. Подпись кривыми буквами: «Братику на остраф». Через «ф». Кто-то маленький очень старался."))
		lines.append(_plain("narrator", "Ты не знаешь, кто это нарисовал. Но знаешь, что он хранил рисунок рядом с подушкой."))

	if knew_letter2:
		lines.append(_plain("narrator", "Связка писем, перевязанная бечёвкой. Два от матери — ты помнишь, он читал вслух. И два его ответа — черновики, с зачёркнутыми строками. Слова подбирал долго. Врал аккуратно."))
		lines.append(_plain("narrator", "«Кормят нормально». «Тут хорошие люди». «Не волнуйся». Каждое предложение — крохотная ложь, за которой стоит крохотная любовь."))
	elif knew_letter1:
		lines.append(_plain("narrator", "Письмо от матери — он показывал тебе. И его ответ, черновик с помарками. Рядом — второе письмо, уже нераспечатанное."))
		lines.append(_plain("narrator", "Он не успел прочитать. Ты открываешь. «Сынок. Ника перестала спрашивать, когда ты приедешь. Просто рисует кораблики. Их уже семь. Она просит привезти ракушку — самую большую…»"))
		lines.append(_plain("narrator", "Ты перестаёшь читать. Ракушка лежит на матрасе. Обломанная."))
	else:
		lines.append(_plain("narrator", "Связка писем, перевязанная бечёвкой. От матери — два, исписанных торопливым почерком. Ты не знал, что он переписывался."))
		lines.append(_plain("narrator", "Первое: «Сынок. Просто скажи — жив. Мне хватит. Ника спрашивает каждое утро». Второе: «Ника перестала спрашивать. Она просит привезти ракушку. Самую большую. Пожалуйста. Вернись живым. Мама»."))
		lines.append(_plain("narrator", "Его черновики ответов — с зачёркнутыми строками. Он подбирал слова. «Не волнуйся» зачёркнуто трижды. Оставлено: «У меня всё хорошо»."))
		lines.append(_plain("narrator", "Ракушка — на матрасе. Обломанная. Ника ждёт."))

	if not knew_camp and not knew_letter1:
		lines.append(_plain("narrator", "Ты стоишь у чужой койки с чужими письмами. Он был рядом — и ты не спросил, как зовут его сестру."))

	lines.append(_plain("narrator", "Ты берёшь всё. Ракушку, письма, рисунок. Он просил — ты обещал."))


func _plain(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

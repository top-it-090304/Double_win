extends DialogueSequence

## Реакция ветерана на truth_and_choice — его позиция.
## Ветеран прокоронный, прагматик. Но правда о печатях его потрясла.


func ensure_lines_ready() -> void:
	if not lines.is_empty():
		return
	id = "veteran_truth_react"

	lines.append(_plain("veteran", "Рыцарь. Я слышал, что монах тебе рассказал. Про печати. Про Зарю. Про свою дочь."))
	lines.append(_plain("hero", "Ты знал?"))
	lines.append(_plain("veteran", "Нет. И в этом вся мерзость. Я был здесь пятнадцать лет. Я потерял одиннадцать друзей на этих островах. И ни разу — ни разу — никто не сказал мне, что стражи — замки."))
	lines.append(_plain("veteran", "Монах знал. Орден знал. Корона — возможно. А я стоял у стрельбища и учил людей стрелять в то, что оказалось… запором на двери."))
	lines.append(_plain("hero", "Как ты это воспринимаешь?"))
	lines.append(_plain("veteran", "Как удар ножом в спину — но тупым концом. Не убивает, но тошнит."))
	lines.append(_plain("veteran", "Марс погиб, штурмуя замок, а не врага. Кит, Дара, Ольм — все они атаковали дверь, которая не хотела их трогать, пока мы не подошли. Мы были агрессорами."))
	if StoryState.has_flag("hero_chose_refuse_chain"):
		lines.append(_plain("veteran", "Ты отказался снимать последнюю печать. Мне это… тяжело принять. Мои друзья начали это дело. Ты мог закончить. Но…"))
		lines.append(_plain("veteran", "Но если стражи — замки, и за ними спит нечто, чего никто не понимает… может, оставить один замок — не трусость. Может, это единственный умный ход за пятнадцать лет."))
		lines.append(_plain("veteran", "Я не согласен. Но я… понимаю."))
	else:
		lines.append(_plain("veteran", "Ты выбрал идти до конца. Снял все печати. Я бы сделал то же самое. Маяки гаснут, люди тонут — это не абстракция, это факт. Руда нужна материку, и стражи стояли на пути."))
		lines.append(_plain("veteran", "Но теперь, зная, что они были замками… Я не жалею. Но вкус победы — другой. С горечью."))
	lines.append(_plain("veteran", "Одно знаю точно: монах молчал пятнадцать лет, пока я хоронил своих в голове каждую ночь. За это я его не прощу. Не сегодня."))


func _plain(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

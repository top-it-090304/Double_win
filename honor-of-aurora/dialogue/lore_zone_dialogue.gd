func ensure_lines_ready() -> void:
	if not lines.is_empty():
		return
	id = dialogue_key
	var rows: Array = LORE_TABLE.get(dialogue_key, [])
	for row in rows:
		if row is Array and row.size() >= 2:
			lines.append(_line(str(row[0]), str(row[1])))


func _line(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

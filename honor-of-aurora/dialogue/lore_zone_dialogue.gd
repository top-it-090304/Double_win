extends DialogueSequence

## Серьёзные диалоги у целителя в зоне лечения (авто при входе). Ключ = id в DialogueRegistry.
## Мир: архипелаг Аврора — цепь «узлов», о которых старые договоры говорили «не будить».
## Название в лоре: морская примета и монастырские глоссы («заря в воде»), не культ богини в кадре.
## Линия monk_story_* (авто при входе): база, орден, цепь — без личных исповедей. Личное — в хабе «О тебе».

@export var dialogue_key: String = ""


extends DialogueSequence

## Дежурные короткие фразы, когда сюжетные диалоги и шутки по походу закончились.
const _DUTY: Array[String] = [
	"Постой у огня — силы вернутся. Пока новостей нет, кроме твоих шагов.",
	"Сегодня без проповедей: только отвар и тишина.",
	"Если нечего сказать — это тоже лекарство. Пей.",
	"Новостей нет. Раны есть. Начнём с ран.",
	"Котёл не хранит мудрость — только температуру. Подожди остывания.",
	"Я здесь. Ты здесь. Остальное подождёт.",
	"Тихо — не значит безопасно, но сегодня мне хватит тишины.",
	"Корона молчит, волны молчат, я молчу. Твоя очередь отдыхать.",
	"Не требуй от меня сюжета — требуй от тела честности.",
	"Флакон тот же. Ты — чуть живее. Уже прогресс.",
	"Если ждёшь откровения — оно в том, что ты всё ещё дышишь.",
	"На сегодня хватит слов. Осталось — сон и шов.",
]


func ensure_lines_ready() -> void:
	lines.clear()
	id = "healer_idle_fallback"
	var l := DialogueLine.new()
	l.speaker_id = "healer"
	l.text = _DUTY[randi() % _DUTY.size()]
	lines.append(l)

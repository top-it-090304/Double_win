extends DialogueSequence

## Дежурные короткие фразы, когда сюжетные диалоги и шутки закончились.
## Не пересекаются с heal_banter_dialogue; тут — минимум слов, максимум характера.
const _DUTY: Array[String] = [
	"Постой у огня. Силы вернутся. Новости — нет.",
	"Сегодня без проповедей. Только отвар.",
	"Раны есть? Тогда подходи. Нет? Тогда просто стой — тишина тоже лечит.",
	"Котёл готов. Ты — почти. Начнём с котла.",
	"Я тут. Ты тут. Мир подождёт.",
	"Флакон — тот же. Ты — живее. Прогресс.",
	"Если ждёшь мудрости — сегодня у меня только температура и бульон.",
	"Тихий день. Для короны — скука. Для меня — подарок.",
	"Дышишь? Дышишь. Этого достаточно. Остальное — завтра.",
	"Волны тихие. Стрелы не свистят. Можно выдохнуть.",
	"Корабль не пришёл. Почта не пришла. Я тоже никуда не ухожу.",
	"Не спрашивай. Просто пей. Иногда молчание — самый честный разговор.",
]


func ensure_lines_ready() -> void:
	lines.clear()
	id = "healer_idle_fallback"
	var l := DialogueLine.new()
	l.speaker_id = "healer"
	l.text = _DUTY[randi() % _DUTY.size()]
	lines.append(l)

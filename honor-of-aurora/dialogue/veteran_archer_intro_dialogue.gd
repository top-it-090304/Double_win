extends DialogueSequence

## Первая встреча с ветераном-лучником у стрельбища. Автозапуск при подходе к Archery zone.


func ensure_lines_ready() -> void:
	if not lines.is_empty():
		return
	id = "veteran_archer_intro"
	lines.append(_plain("veteran", "Стой."))
	lines.append(_plain("veteran", "Ты тот рыцарь, которого прислала корона. Я видел, как ты сошёл с корабля. Походка уверенная, плечи прямые. Это пройдёт."))
	lines.append(_plain("hero", "А ты?"))
	lines.append(_plain("veteran", "Бран. Бывший королевский стрелок. Первая экспедиция на Аврору — пятнадцать лет назад. Мы были здесь до монахов, до базы, до указа. Двадцать человек. Вернулись девять. Я — с хромой ногой."))
	lines.append(_plain("hero", "Первая экспедиция? О ней ничего не было в моём указе."))
	lines.append(_plain("veteran", "Разумеется. Дворец не пишет про провалы. Мы нашли стражей, потеряли половину роты и получили приказ молчать. Я остался, потому что идти некуда, а на этих островах хотя бы есть смысл."))
	lines.append(_plain("veteran", "Теперь тренирую лучников. Видишь десяток на стенах? Мои. Каждого учил сам — от стойки до первого выстрела под страхом."))
	lines.append(_plain("hero", "Что ты знаешь о стражах?"))
	lines.append(_plain("veteran", "То, чего не напишут в монашеских текстах. Первый страж разорвал моего лейтенанта на моих глазах. Не потому что «охранял сон» — потому что мог. Монах расскажет тебе про печати и священные замки. Я расскажу другое: они убивают быстро, и им всё равно, веришь ты в Зарю или нет."))
	lines.append(_plain("veteran", "Хочешь совет от того, кто выжил? Не спеши. Стреляй первым. И не слушай тех, кто видел стражей только в книгах."))
	lines.append(_plain("hero", "Я запомню."))
	lines.append(_plain("veteran", "Запоминай. А когда вернёшься с первого острова — приходи. Расскажу, что помню. Может, пригодится больше, чем отвары монаха."))


func _plain(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

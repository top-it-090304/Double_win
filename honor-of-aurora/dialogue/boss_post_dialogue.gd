class_name BossPostDialogue
extends DialogueSequence

## 1..5 — номер побеждённого босса (по счётчику SaveManager.boss_kill).
@export var boss_index: int = 1


func _notification(what: int) -> void:
	if what == NOTIFICATION_POSTINITIALIZE:
		lines.clear()
		_ensure_lines()


func ensure_lines_ready() -> void:
	_ensure_lines()


func _ensure_lines() -> void:
	if not lines.is_empty():
		return
	id = "boss_post_%d" % boss_index
	var arr: Array[DialogueLine] = []
	match boss_index:
		1:
			arr.append(_line("healer", "Ты вернулся. И даже ходишь — сколько в тебе, странник…"))
			arr.append(_line("hero", "Первый «хозяин» острова пал. Твари были… слишком ровные, как по нотам."))
			arr.append(_line("healer", "Ровные — плохой знак. На кости у старых стражей иногда видели клеймо… похожее на корону. Шутка ли, совпадение ли — не спеши делать выводы."))
			arr.append(_line("healer", "Король ждёт руду и тишину. А я жду, чтобы ты возвращался живым. Ступай в круг — и поменьше геройствуй на пустом желудке."))
		2:
			arr.append(_line("hero", "Второй остров… Там не было шахты. На карте шахта была."))
			arr.append(_line("healer", "Вот именно. Кое-кто рисует руду карандашом задним числом. Архипелаг Аврора помнит старые договоры — не про добычу, а про… тишину."))
			arr.append(_line("hero", "Ты знал?"))
			arr.append(_line("healer", "Я знаю, как перевязать. И что люди охотнее верят приказу, чем печати. Держи настойку. И не спрашивай, из чего — из того, что не кусается."))
		3:
			arr.append(_line("healer", "Слышал колокол? Третий на Тихой Отмели не бился три ночи. Как только ты ушёл — он… отозвался. Архипелаг нервничает."))
			arr.append(_line("hero", "Я выполняю указ. Освобождаю острова."))
			arr.append(_line("healer", "Слова прекрасные. Только в старом договоре ордена не «освобождать», а «не будить». Я служил при том тексте. Мне за это не платят — платят за швы."))
			arr.append(_line("hero", "…Тогда почему ты помогаешь мне?"))
			arr.append(_line("healer", "Потому что ты — уже здесь. И я предпочитаю лечить живого идиота, чем хоронить мёртвого героя."))
		4:
			arr.append(_line("hero", "Эти «боссы»… они не звериные вожаки. Как будто держали что-то на месте."))
			arr.append(_line("healer", "Прослойка. Как болты в двери, которую не открывали веками. Ты снял ещё один. Дверь скрипит."))
			arr.append(_line("hero", "Ты говорил это так, будто это хорошо."))
			arr.append(_line("healer", "Я говорю это так, будто это факт. Клятва — дурацкая штука: мешает кричать тебе в лицо. Но сегодня я кричать не буду. Сегодня — только лечение. И молитва."))
		5:
			arr.append(_line("hero", "Последний пал. Я сделал всё по указу. Архипелаг… свободен?"))
			arr.append(_line("healer", "Свободен от стражей. Не от последствий. Ты выполнил приказ. Только указ был не про шахты."))
			arr.append(_line("hero", "О чём ты?"))
			arr.append(_line("healer", "Про Аврору. Её называют островом, а она — дыхание цепи островов. Стражи были не врагами короны. Они были замками."))
			arr.append(_line("healer", "Ты снял замки. И теперь… слышишь? Под тиной воды — не волны. Кто-то вздохнул впервые за столетия."))
			arr.append(_line("hero", "Что я…"))
			arr.append(_line("healer", "Ты сделал всё правильно по бумаге. А бумага — чужая. Если хочешь понять, кто воспользовался твоим мечом… иди за горизонт, где корона кончается. Там начинается вторая история."))
			arr.append(_line("narrator", "Часть первая завершена. Но Аврора только проснулась."))
		_:
			arr.append(_line("healer", "…"))
	lines = arr


func _line(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

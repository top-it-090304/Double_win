class_name BossPostDialogue
extends DialogueSequence

## 1..5 — номер реплики после острова. Доступ задаётся флагами story_island_N_cleared + цепочка boss_post_{N-1}_done (см. DialogueDefinition).
@export var boss_index: int = 1


func _notification(what: int) -> void:
	if what == NOTIFICATION_POSTINITIALIZE:
		lines.clear()
		_ensure_lines()


func ensure_lines_ready() -> void:
	_ensure_lines()


func _ensure_lines() -> void:
	if not lines.is_empty():
		return
	id = "boss_post_%d" % boss_index
	var arr: Array[DialogueLine] = []
	match boss_index:
		1:
			arr.append(_line("healer", "Ты вернулся. И на ногах — уже хорошо."))
			arr.append(_line("hero", "Страж мёртв. Но он дрался странно — не как зверь. Словно охранял вход, а не логово."))
			arr.append(_line("healer", "Ты заметил. На костях старых стражей находили клеймо — восьмиконечную звезду. Такую же носит мой орден. Это не дикие твари, странник."))
			arr.append(_line("hero", "Ты хочешь сказать, что стражей поставили люди?"))
			arr.append(_line("healer", "Я хочу сказать, что ты вернулся живым. Поешь, отдохни. Остальное — потом."))
			if StoryState.has_flag("veteran_archer_intro_done"):
				arr.append(_line("veteran", "Первый страж. Ты сделал то, что мы не смогли пятнадцать лет назад. Хорошо. Но не расслабляйся — дальше тяжелее."))
		2:
			arr.append(_line("hero", "Второй остров взят. Но по карте короны там должна быть шахта. На месте — пустая скала."))
			arr.append(_line("healer", "Потому что карту рисовали не по разведке, а по желанию казначея. Рудники на материке иссякают. Короне нужна сердцевина — любой ценой. На базе есть только верхняя жила: крохи для лагеря и отчётов. Настоящие жилы под соседними островами закрыты стражами. Шахту нарисовали, чтобы указ выглядел как экономический проект, а не как то, чем он является."))
			arr.append(_line("hero", "Чем он является?"))
			arr.append(_line("healer", "Спроси через два острова. Сейчас у меня для тебя только настойка и совет: не верь картам, на которых стоит дворцовая печать."))
			if StoryState.has_flag("veteran_archer_intro_done"):
				arr.append(_line("veteran", "Шахты нет? Казначей рисовал. Но руда — настоящая, она глубже, под стражами. На базе снимают верхний слой, а не жилу. Когда снимешь печати — рудники откроются. Карта лжёт в деталях, не в сути."))
		3:
			arr.append(_line("healer", "Колокол на Тихой Отмели молчал всё время, пока ты был на острове. Стоило тебе уйти — он зазвонил. Три удара. Такого не было сто лет."))
			arr.append(_line("hero", "Я выполняю указ. Почему архипелаг реагирует так, будто я делаю что-то не то?"))
			arr.append(_line("healer", "Потому что в старом договоре ордена с короной было другое слово. Не «освободить» — «не будить». Я служил при том тексте. Новый указ короля его перечеркнул."))
			arr.append(_line("hero", "Что именно нельзя будить?"))
			arr.append(_line("healer", "Под архипелагом спит то, что дало ему имя. Заря. Не богиня — сила. Первый свет в воде. Стражи держали её сон. С каждым убитым стражем сон тоньше."))
			arr.append(_line("hero", "Ты знал это с самого начала."))
			arr.append(_line("healer", "Знал. И молчал. У меня свои причины. Не все из них чистые."))
			if StoryState.has_flag("veteran_archer_intro_done"):
				arr.append(_line("veteran", "«Заря». Монах и его красивые слова. Я видел, что стражи делают с людьми. Мне всё равно, как это называется — «печать», «сила», «бог». Если оно убивает моих людей — оно враг."))
		4:
			arr.append(_line("hero", "Четвёртый страж… он не нападал первым. Он стоял и смотрел, пока я не ударил. Как будто ждал."))
			arr.append(_line("healer", "Они не враги, странник. Они были печатями. Живыми замками, которые орден поставил столетия назад, чтобы сон Зари оставался нетронутым."))
			arr.append(_line("healer", "Ты снял четыре из пяти. Остался один. И мне пора сказать тебе то, что я откладывал с первого дня."))
			arr.append(_line("hero", "Говори."))
			arr.append(_line("healer", "Не здесь. Не так. Приходи ко мне в церковь, когда будешь готов. Разговор будет долгим. И после него ты сам решишь, идти ли на последний остров."))
			if StoryState.has_flag("veteran_archer_intro_done"):
				arr.append(_line("veteran", "Четвёртый. Один остался. Рыцарь, я не знаю, что монах тебе скажет в церкви. Но вот что скажу я: мои друзья погибли, чтобы начать это дело. Закончи его. За них."))
		5:
			if StoryState.has_flag("truth_and_choice_done"):
				arr.append(_line("healer", "Ты знал, что делаешь, когда шёл на последний остров. Это был твой выбор — не мой и не короны."))
			if StoryState.has_flag("worker_youth_dead"):
				arr.append(_line("healer", "…Юноша не вернулся. Ты это уже знаешь. Я не буду повторять."))
			arr.append(_line("hero", "Последний страж пал. Указ выполнен. Архипелаг свободен?"))
			arr.append(_line("healer", "От замков — да. От того, что под ними, — нет."))
			arr.append(_line("healer", "Слышишь? Вода светится. Деревья скрипят без ветра. Под землёй — гул, которого здесь не было сто лет."))
			arr.append(_line("healer", "Заря просыпается. Не мгновенно — медленно, как рассвет. Но процесс уже не остановить."))
			arr.append(_line("hero", "Что будет, когда она проснётся полностью?"))
			arr.append(_line("healer", "Этого не знает никто. Ни орден, ни корона. Старые тексты расходятся: одни пишут о благе, другие — о потопе. Единственное, в чём они сходятся, — мир уже не будет прежним."))
			arr.append(_line("hero", "Что я наделал…"))
			arr.append(_line("healer", "То, что тебе приказали. То, о чём я промолчал. То, за что корона получит свою руду, а я… свой билет домой. Вина — общая. Не неси её один."))
			if StoryState.has_flag("veteran_archer_intro_done"):
				arr.append(_line("veteran", "Готово. Все пять. Марс, Кит, Дара, Ольм… вы слышите? Ваш поход закончен. Кто-то довёл дело до конца."))
			arr.append(_line("narrator", "Замки сняты. Аврора просыпается. Что будет дальше — не решит ни указ, ни меч. Первый круг замкнулся."))
		_:
			arr.append(_line("healer", "…"))
	lines = arr


func _line(speaker_id: String, text: String) -> DialogueLine:
	var l := DialogueLine.new()
	l.speaker_id = speaker_id
	l.text = text
	return l

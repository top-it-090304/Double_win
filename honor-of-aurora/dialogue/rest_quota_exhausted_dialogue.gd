extends DialogueSequence

## Дежурная реплика при исчерпанном лимите привалов за поход (техническое ограничение, без сюжета).
## Акцент: за один выход съесть больше нельзя; мясо не добавит лечения — нужен целитель на базе.
const _LINES: Array[String] = [
	"За один поход я столько уже не съем — желудок не резиновый.",
	"С меня на этот выход хватит. Ещё мяса не впихну — это не лечит, только тяжесть.",
	"Я уже наелся насколько можно в дороге. Больше порций — не больше сил.",
	"Мясо не поможет: лимит на поход выбран, организм не примет ещё такой же объём.",
	"Не могу столько съесть за раз — даже если мясо есть. Это не лекарство, а еда.",
	"Стоп. На этом острове я больше так не насыщусь — нужен целитель на базе, не котёл.",
	"Съел сколько положено за поход. Ещё — впустую, врач нужен, не жареное.",
	"За один выход желудок выдерживает только столько привалов. Дальше только к целителю.",
	"Не влезет. Мясо не заменит лечение — когда лимит съедено, остаётся база.",
	"Я физически не могу снова так наесться в этом походе. Ищи целителя, не запас.",
	"Один поход — один запас «перекусов». Сверх — не переварю; мясо тут не чинит раны.",
	"Уже достаточно на один выход. Больше мяса не сделает меня здоровее — нужен лекарь.",
]


func ensure_lines_ready() -> void:
	lines.clear()
	id = "rest_quota_exhausted"
	var l := DialogueLine.new()
	l.speaker_id = "hero"
	l.text = _LINES[randi() % _LINES.size()]
	lines.append(l)

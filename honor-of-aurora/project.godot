; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Honor of Aurora"
run/main_scene="uid://b0oiqjmnjpppv"
config/features=PackedStringArray("4.4", "GL Compatibility")

[autoload]

SaveManager="*res://autoload/Save_manager.gd"
DifficultyConfig="*res://autoload/DifficultyConfig.gd"
BalanceConfig="*res://autoload/BalanceConfig.gd"
Events="*res://autoload/Events.gd"
SquadOrders="*res://autoload/SquadOrders.gd"
SquadCombatState="*res://autoload/SquadCombatState.gd"
StoryState="*res://autoload/StoryState.gd"
GameplayFacade="*res://autoload/GameplayFacade.gd"
MenuStartTransition="*res://autoload/MenuStartTransition.gd"
GameManager="*res://autoload/GameManager.gd"
SoundManager="*res://autoload/SoundManager.gd"
DialogueManager="*res://autoload/DialogueManager.gd"
DialogueRegistry="*res://autoload/DialogueRegistry.gd"
MobileVirtualInput="*res://autoload/MobileVirtualInput.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

attack={
"deadzone": 0.2,
"events": []
}
shield={
"deadzone": 0.2,
"events": []
}

[input_devices]

pointing/emulate_mouse_from_touch=false

[layer_names]

2d_physics/layer_1="enemy"
2d_physics/layer_2="player"
2d_physics/layer_3="borderline"
2d_physics/layer_4="ally"
2d_physics/layer_5="arrow"
2d_physics/layer_6="zone"

[navigation]

3d/merge_rasterizer_cell_scale=0.001

[physics]

2d/default_gravity=0.0

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true

# Payments backend environment template (safe for git)
# Copy to .env (or export vars in shell) and fill real values locally.

# SQLAlchemy connection string.
# Dev default matches current project setup.
DATABASE_URL=sqlite:///./app.db

# Payment provider implementation to use.
# Current supported value: stub
PAYMENT_PROVIDER=stub

# Stub webhook signature behavior:
# - true  => do not require signature (dev only)
# - false => require X-Stub-Signature computed with STUB_WEBHOOK_SECRET
STUB_ALLOW_INSECURE_WEBHOOK=true

# Secret for stub webhook signature verification.
# Keep empty in git; set a strong random value locally for strict mode.
STUB_WEBHOOK_SECRET=

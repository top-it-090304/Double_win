# Репозиторий в LF. Рабочая копия тоже LF: см. honor-of-aurora/.editorconfig (root) и .vscode/settings.json.
# При предупреждениях о CRLF: git config core.autocrlf false (локально в этом репо).
* text=auto eol=lf

*.tscn text eol=lf
*.gd text eol=lf
*.uid text eol=lf
*.godot text eol=lf
*.cfg text eol=lf
*.import text eol=lf
*.md text eol=lf
